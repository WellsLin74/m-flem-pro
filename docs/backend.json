
{
  "entities": {
    "UserPermission": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserPermission",
      "type": "object",
      "description": "Represents a user's permissions and assigned company within the M-FLEM Pro system.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string" },
        "assignedCompany": { "type": "string" },
        "isApproved": { "type": "boolean", "description": "Whether the user has been approved by an ADMIN." }
      },
      "required": ["id", "email", "role", "assignedCompany", "isApproved"]
    },
    "Plant": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Plant",
      "type": "object",
      "description": "Consolidated entity for a plant's physical and financial baseline data.",
      "properties": {
        "id": { "type": "string" },
        "companyName": { "type": "string" },
        "plantName": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "fabAboveLevel": { "type": "number" },
        "fabBelowLevel": { "type": "number" },
        "cupAboveLevel": { "type": "number" },
        "cupBelowLevel": { "type": "number" },
        "fabLength": { "type": "number" },
        "fabWidth": { "type": "number" },
        "cupLength": { "type": "number" },
        "cupWidth": { "type": "number" },
        "buildingValue": { "type": "number" },
        "facilityValue": { "type": "number" },
        "toolsValue": { "type": "number" },
        "fixtureValue": { "type": "number" },
        "stockValue": { "type": "number" },
        "bi12mValue": { "type": "number" }
      },
      "required": ["id", "companyName", "plantName"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/user_permissions/{userId}",
        "definition": {
          "entityName": "UserPermission",
          "schema": { "$ref": "#/backend/entities/UserPermission" },
          "description": "User profile and authorization."
        }
      },
      {
        "path": "/plants/{plantId}",
        "definition": {
          "entityName": "Plant",
          "schema": { "$ref": "#/backend/entities/Plant" },
          "description": "Consolidated physical and financial data for a plant."
        }
      }
    ]
  }
}
