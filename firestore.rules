rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 基本登入檢查
    function isSignedIn() {
      return request.auth != null;
    }
    
    // 檢查是否為管理員 (優先檢查 Email 以確保系統初始存取權)
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "admin@marsh.com" ||
        (exists(/databases/$(database)/documents/user_permissions/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/user_permissions/$(request.auth.uid)).data.role == 'ADMIN')
      );
    }

    // 檢查公司存取權限
    function hasAccess(companyName) {
      return isSignedIn() && (
        isAdmin() || (
          exists(/databases/$(database)/documents/user_permissions/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/user_permissions/$(request.auth.uid)).data.assignedCompany == companyName
        )
      );
    }

    // 使用者權限
    match /user_permissions/{userId} {
      allow get: if isSignedIn();
      allow write: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
    }

    // 工廠主表 (包含 P3 的基準數據)
    match /plants/{plantId} {
      allow read: if isSignedIn();
      allow write: if hasAccess(request.resource.data.companyName);
      allow delete: if isAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/user_permissions/$(request.auth.uid)) && get(/databases/$(database)/documents/user_permissions/$(request.auth.uid)).data.assignedCompany == resource.data.companyName);
    }

    // 潔淨室佔用比例 (P4)
    match /fab_cleanroom_occupancy/{id} {
      allow read: if isSignedIn();
      allow write: if hasAccess(request.resource.data.companyName);
      match /floor_ratios/{fid} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
    }

    // 資產價值分佈比例 (P5)
    match /building_value_ratios/{id} {
      allow read: if isSignedIn();
      allow write: if hasAccess(request.resource.data.companyName);
      match /floor_ratios/{fid} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
    }

    // 洪水損失模擬紀錄 (P6)
    match /flood_loss_estimations/{id} {
      allow read: if isSignedIn();
      allow create: if hasAccess(request.resource.data.companyName);
      allow update, delete: if isAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/user_permissions/$(request.auth.uid)) && get(/databases/$(database)/documents/user_permissions/$(request.auth.uid)).data.assignedCompany == resource.data.companyName);
    }
  }
}