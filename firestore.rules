rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic Auth
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Admin Check (Priority)
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "admin@marsh.com" ||
        (exists(/databases/$(database)/documents/user_permissions/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/user_permissions/$(request.auth.uid)).data.role == 'ADMIN')
      );
    }

    // Company Access Logic
    function getCompany() {
      return get(/databases/$(database)/documents/user_permissions/$(request.auth.uid)).data.assignedCompany;
    }

    function hasAccess(compName) {
      return isSignedIn() && (isAdmin() || getCompany() == compName);
    }

    // Helper for write operations (checks both request and resource)
    function canWrite(compName) {
      return hasAccess(compName);
    }

    // User Permissions
    match /user_permissions/{userId} {
      allow get: if isSignedIn();
      allow write: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
    }

    // Plant Main Table (Consolidated)
    match /plants/{plantId} {
      allow read: if isSignedIn();
      allow create, update: if canWrite(request.resource.data.companyName);
      allow delete: if isAdmin() || (isSignedIn() && getCompany() == resource.data.companyName);
    }

    // Cleanroom Ratios (P4)
    match /fab_cleanroom_occupancy/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && request.resource.data.companyName != null && hasAccess(request.resource.data.companyName));
      
      match /floor_ratios/{fid} {
        allow read: if isSignedIn();
        allow write: if isAdmin() || isSignedIn();
      }
    }

    // Asset Distribution Matrix (P5)
    match /building_value_ratios/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && request.resource.data.companyName != null && hasAccess(request.resource.data.companyName));
      
      match /floor_ratios/{fid} {
        allow read: if isSignedIn();
        allow write: if isAdmin() || isSignedIn();
      }
    }

    // Flood Loss Estimations (P6)
    match /flood_loss_estimations/{id} {
      allow read: if isSignedIn();
      allow create: if canWrite(request.resource.data.companyName);
      allow update, delete: if isAdmin() || (isSignedIn() && getCompany() == resource.data.companyName);
    }
  }
}