rules_version = '2';

/**
 * FIRESTORE SECURITY RULES - M-FLEM Pro
 * 
 * CORE PHILOSOPHY:
 * This ruleset implements a strict multi-tenant security model based on "Authorization Independence via Denormalization." 
 * Access is primarily governed by a user's assigned company, which is verified against denormalized 'companyName' 
 * fields present on every document. This approach optimizes performance and security by eliminating 
 * cross-document lookups (get() calls) during authorization.
 *
 * DATA STRUCTURE:
 * - /user_permissions/{userId}: User-specific metadata and authorization source of truth.
 * - /{collection}/{documentId}: Global collections for building info, plant values, and estimations, 
 *   partitioned by 'companyName'.
 * - /.../floor_ratios/{id}: Nested subcollections that maintain the 'companyName' link for independent auth.
 *
 * KEY SECURITY DECISIONS:
 * 1. Custom Claims Usage: Rules rely on 'assignedCompany' and 'role' custom claims (minted from UserPermission) 
 *    for rapid, stateless authorization.
 * 2. Immutability: The 'companyName' field is immutable once a document is created to prevent tenant-hopping.
 * 3. Denormalization: Every document in the system, including those in subcollections, must contain the 
 *    'companyName' to facilitate local authorization checks.
 * 4. Prototyping Mode: Logic focuses on strict authorization and relational integrity (company links) 
 *    rather than exhaustive data type validation.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user is authorized for a specific company based on their custom token claim. */
    function hasCompanyAccess(companyName) {
      return isSignedIn() && request.auth.token.assignedCompany == companyName;
    }

    /** @description Verifies that a document exists and the user belongs to the company that owns it. */
    function isExistingTenantOwner(currentData) {
      return currentData != null && hasCompanyAccess(currentData.companyName);
    }

    /** @description Ensures that the tenant link (companyName) remains unchanged during an update. */
    function isTenantImmutable() {
      return request.resource.data.companyName == resource.data.companyName;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Access rules for user metadata and permissions.
     * @path /user_permissions/{userId}
     * @allow (get, create) If request.auth.uid == userId
     * @deny (list) If any user attempts to list all permission records.
     * @principle Path-based ownership for private user data.
     */
    match /user_permissions/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Users should not be able to list other users' permissions
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && resource != null;
      allow delete: if isOwner(userId) && resource != null;
    }

    /**
     * @description Access rules for building physical information.
     * @path /building_info/{buildingInfoId}
     * @allow (list) If user provides their assignedCompany in the query.
     * @deny (update) If user attempts to change the companyName field.
     * @principle Shared access restricted by tenant (companyName).
     */
    match /building_info/{buildingInfoId} {
      allow get: if hasCompanyAccess(resource.data.companyName);
      allow list: if isSignedIn() && hasCompanyAccess(request.query.limit > 0 ? request.auth.token.assignedCompany : ""); 
      allow create: if hasCompanyAccess(request.resource.data.companyName);
      allow update: if isExistingTenantOwner(resource.data) && isTenantImmutable();
      allow delete: if isExistingTenantOwner(resource.data);
    }

    /**
     * @description Access rules for plant asset initial values.
     * @path /plant_initial_values/{plantInitialValueId}
     * @allow (create) If incoming companyName matches user's assignedCompany.
     * @deny (get) If document companyName does not match user's assignedCompany.
     * @principle Multi-tenancy via denormalized company fields.
     */
    match /plant_initial_values/{plantInitialValueId} {
      allow get: if hasCompanyAccess(resource.data.companyName);
      allow list: if isSignedIn() && hasCompanyAccess(request.auth.token.assignedCompany);
      allow create: if hasCompanyAccess(request.resource.data.companyName);
      allow update: if isExistingTenantOwner(resource.data) && isTenantImmutable();
      allow delete: if isExistingTenantOwner(resource.data);
    }

    /**
     * @description Access rules for cleanroom occupancy summaries.
     * @path /fab_cleanroom_occupancy/{fabCleanroomOccupancyId}
     * @allow (update) Only for users belonging to the company owning the plant.
     * @deny (create) If companyName is missing or mismatched.
     * @principle Tenant-based authorization with immutable ownership links.
     */
    match /fab_cleanroom_occupancy/{fabCleanroomOccupancyId} {
      allow get: if hasCompanyAccess(resource.data.companyName);
      allow list: if isSignedIn() && hasCompanyAccess(request.auth.token.assignedCompany);
      allow create: if hasCompanyAccess(request.resource.data.companyName);
      allow update: if isExistingTenantOwner(resource.data) && isTenantImmutable();
      allow delete: if isExistingTenantOwner(resource.data);

      /**
       * @description Access rules for floor-specific cleanroom ratios.
       * @path /fab_cleanroom_occupancy/{fabCleanroomOccupancyId}/floor_ratios/{fabCleanroomFloorRatioId}
       * @allow (get) Using denormalized companyName on the subcollection document.
       * @principle Authorization Independence for subcollections via denormalization.
       */
      match /floor_ratios/{fabCleanroomFloorRatioId} {
        allow get: if hasCompanyAccess(resource.data.companyName);
        allow list: if isSignedIn() && hasCompanyAccess(request.auth.token.assignedCompany);
        allow create: if hasCompanyAccess(request.resource.data.companyName);
        allow update: if isExistingTenantOwner(resource.data) && isTenantImmutable();
        allow delete: if isExistingTenantOwner(resource.data);
      }
    }

    /**
     * @description Access rules for validated building value ratios.
     * @path /building_value_ratios/{buildingValueRatioId}
     * @allow (get) If doc.companyName matches user.assignedCompany.
     * @principle Multi-tenant separation for sensitive financial ratios.
     */
    match /building_value_ratios/{buildingValueRatioId} {
      allow get: if hasCompanyAccess(resource.data.companyName);
      allow list: if isSignedIn() && hasCompanyAccess(request.auth.token.assignedCompany);
      allow create: if hasCompanyAccess(request.resource.data.companyName);
      allow update: if isExistingTenantOwner(resource.data) && isTenantImmutable();
      allow delete: if isExistingTenantOwner(resource.data);

      /**
       * @description Access rules for floor-specific building value distributions.
       * @path /building_value_ratios/{buildingValueRatioId}/floor_ratios/{buildingValueFloorRatioId}
       * @allow (list) Performed efficiently without parent document lookups.
       * @principle Performance optimization using denormalized auth context.
       */
      match /floor_ratios/{buildingValueFloorRatioId} {
        allow get: if hasCompanyAccess(resource.data.companyName);
        allow list: if isSignedIn() && hasCompanyAccess(request.auth.token.assignedCompany);
        allow create: if hasCompanyAccess(request.resource.data.companyName);
        allow update: if isExistingTenantOwner(resource.data) && isTenantImmutable();
        allow delete: if isExistingTenantOwner(resource.data);
      }
    }

    /**
     * @description Access rules for flood loss estimation results.
     * @path /flood_loss_estimations/{floodLossEstimationId}
     * @allow (create) If estimation results are linked to the user's assigned company.
     * @deny (delete) If the user belongs to a different company.
     * @principle Shared company access with relational integrity validation.
     */
    match /flood_loss_estimations/{floodLossEstimationId} {
      allow get: if hasCompanyAccess(resource.data.companyName);
      allow list: if isSignedIn() && hasCompanyAccess(request.auth.token.assignedCompany);
      allow create: if hasCompanyAccess(request.resource.data.companyName);
      allow update: if isExistingTenantOwner(resource.data) && isTenantImmutable();
      allow delete: if isExistingTenantOwner(resource.data);
    }

  }
}