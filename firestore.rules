rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic sign-in check
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Admin check: Priority on Email for immediate recognition
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "admin@marsh.com" ||
        (exists(/databases/$(database)/documents/user_permissions/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/user_permissions/$(request.auth.uid)).data.role == 'ADMIN')
      );
    }

    // Authorization context for company data
    function hasAccess(compName) {
      return isSignedIn() && (
        isAdmin() || 
        (exists(/databases/$(database)/documents/user_permissions/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/user_permissions/$(request.auth.uid)).data.assignedCompany == compName)
      );
    }

    // Plants Registry
    match /plants/{plantId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin() || (isSignedIn() && hasAccess(request.resource.data.companyName));
      allow delete: if isAdmin();
    }

    // P4: Spatial Distribution
    match /fab_cleanroom_occupancy/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && hasAccess(request.resource.data.companyName));
      
      match /floor_ratios/{fid} {
        allow read: if isSignedIn();
        allow write: if isAdmin() || (isSignedIn() && hasAccess(request.resource.data.companyName));
      }
    }

    // P5: Asset Matrix
    match /building_value_ratios/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && hasAccess(request.resource.data.companyName));
      
      match /floor_ratios/{fid} {
        allow read: if isSignedIn();
        allow write: if isAdmin() || (isSignedIn() && hasAccess(request.resource.data.companyName));
      }
    }

    // P6: Estimations
    match /flood_loss_estimations/{id} {
      allow read: if isSignedIn();
      allow create: if isAdmin() || (isSignedIn() && hasAccess(request.resource.data.companyName));
      allow update, delete: if isAdmin();
    }

    // User Permissions
    match /user_permissions/{userId} {
      allow get: if isSignedIn();
      allow write: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
    }
  }
}
