
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function hasCompanyAccess(companyName) {
      return isSignedIn() && (
        (request.auth.token.assignedCompany == companyName) ||
        (get(/databases/$(database)/documents/user_permissions/$(request.auth.uid)).data.assignedCompany == companyName)
      );
    }

    match /user_permissions/{userId} {
      allow get, create, update, delete: if isOwner(userId);
    }

    match /plants/{plantId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create, update, delete: if hasCompanyAccess(request.resource.data.companyName || resource.data.companyName);
    }

    match /fab_cleanroom_occupancy/{id} {
      allow read, write: if isSignedIn();
      match /floor_ratios/{fid} { allow read, write: if isSignedIn(); }
    }

    match /building_value_ratios/{id} {
      allow read, write: if isSignedIn();
      match /floor_ratios/{fid} { allow read, write: if isSignedIn(); }
    }

    match /flood_loss_estimations/{id} {
      allow read, write: if isSignedIn();
    }
  }
}
