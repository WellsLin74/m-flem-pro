
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic Auth Check
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Helper to get user document
    function getUserDoc() {
      return get(/databases/$(database)/documents/user_permissions/$(request.auth.uid)).data;
    }

    // Explicit Admin Check
    function isAdmin() {
      let path = /databases/$(database)/documents/user_permissions/$(request.auth.uid);
      return isSignedIn() && exists(path) && getUserDoc().role == 'ADMIN';
    }

    // Check company access or admin override
    function hasCompanyAccess(companyName) {
      if (!isSignedIn()) return false;
      let path = /databases/$(database)/documents/user_permissions/$(request.auth.uid);
      if (!exists(path)) return false;
      let userData = getUserDoc();
      return userData.role == 'ADMIN' || userData.assignedCompany == companyName;
    }

    // User Permissions - Users can manage their own, Admins can manage all
    match /user_permissions/{userId} {
      allow get: if isSignedIn();
      allow write: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
    }

    // Plants - Admins or assigned company users
    match /plants/{plantId} {
      allow read: if isSignedIn();
      allow create, update: if hasCompanyAccess(request.resource.data.companyName);
      allow delete: if isAdmin() || hasCompanyAccess(resource.data.companyName);
    }

    // Cleanroom Occupancy
    match /fab_cleanroom_occupancy/{id} {
      allow read: if isSignedIn();
      allow create, update: if hasCompanyAccess(request.resource.data.companyName);
      allow delete: if isAdmin() || hasCompanyAccess(resource.data.companyName);
      
      match /floor_ratios/{fid} { 
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
    }

    // Building Value Ratios
    match /building_value_ratios/{id} {
      allow read: if isSignedIn();
      allow create, update: if hasCompanyAccess(request.resource.data.companyName);
      allow delete: if isAdmin() || hasCompanyAccess(resource.data.companyName);
      
      match /floor_ratios/{fid} { 
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
    }

    // Flood Loss Estimations
    match /flood_loss_estimations/{id} {
      allow read: if isSignedIn();
      allow create: if hasCompanyAccess(request.resource.data.companyName);
      allow update, delete: if isAdmin() || hasCompanyAccess(resource.data.companyName);
    }
  }
}
