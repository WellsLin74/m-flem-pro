rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 基本登入檢查
    function isSignedIn() {
      return request.auth != null;
    }
    
    // 檢查是否已核准 (超級管理員自動核准)
    function isApproved() {
      return isSignedIn() && (
        request.auth.token.email == "admin@marsh.com" ||
        get(/databases/$(database)/documents/user_permissions/$(request.auth.uid)).data.isApproved == true
      );
    }

    // 管理員判斷：優先檢查 Email 或資料庫 Role
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "admin@marsh.com" ||
        (exists(/databases/$(database)/documents/user_permissions/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/user_permissions/$(request.auth.uid)).data.role == 'ADMIN')
      );
    }

    // 角色檢查函數 (需為已核准身分)
    function isEditor() {
      return isApproved() && (
        request.auth.token.email == "admin@marsh.com" ||
        get(/databases/$(database)/documents/user_permissions/$(request.auth.uid)).data.role == 'EDITOR'
      );
    }

    function isReader() {
      return isApproved() && (
        request.auth.token.email == "admin@marsh.com" ||
        get(/databases/$(database)/documents/user_permissions/$(request.auth.uid)).data.role == 'READER'
      );
    }

    // 公司存取權限：ADMIN 可看所有，其餘限所屬公司且需已核准
    function hasAccess(compName) {
      return isSignedIn() && (
        isAdmin() || 
        (isApproved() && get(/databases/$(database)/documents/user_permissions/$(request.auth.uid)).data.assignedCompany == compName)
      );
    }

    // 修改權限：ADMIN 與已核准的 EDITOR 具備修改權限
    function canModify(compName) {
      return isSignedIn() && (
        isAdmin() || 
        (isEditor() && get(/databases/$(database)/documents/user_permissions/$(request.auth.uid)).data.assignedCompany == compName)
      );
    }

    // 工廠資料庫
    match /plants/{plantId} {
      allow list: if isSignedIn();
      allow get: if hasAccess(resource.data.companyName);
      allow create: if canModify(request.resource.data.companyName);
      allow update: if canModify(resource.data.companyName);
      allow delete: if isAdmin();
    }

    // P4: 空間分佈
    match /fab_cleanroom_occupancy/{id} {
      allow list: if isSignedIn();
      allow get: if hasAccess(resource.data.companyName);
      allow write: if canModify(request.resource.data.companyName || resource.data.companyName);
      
      match /floor_ratios/{fid} {
        allow list, get: if isSignedIn();
        allow write: if canModify(get(/databases/$(database)/documents/fab_cleanroom_occupancy/$(id)).data.companyName);
      }
    }

    // P5: 資產價值矩陣
    match /building_value_ratios/{id} {
      allow list: if isSignedIn();
      allow get: if hasAccess(resource.data.companyName);
      allow write: if canModify(request.resource.data.companyName || resource.data.companyName);
      
      match /floor_ratios/{fid} {
        allow list, get: if isSignedIn();
        allow write: if canModify(get(/databases/$(database)/documents/building_value_ratios/$(id)).data.companyName);
      }
    }

    // P6: 淹水損失估算 (登入即可建立模擬，確保靈活性)
    match /flood_loss_estimations/{id} {
      allow list: if isSignedIn();
      allow get: if hasAccess(resource.data.companyName);
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // 使用者權限設定
    match /user_permissions/{userId} {
      allow list: if isAdmin();
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
