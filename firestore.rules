rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic sign-in check
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Admin check: Priority on Email or explicit Role
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "admin@marsh.com" ||
        (exists(/databases/$(database)/documents/user_permissions/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/user_permissions/$(request.auth.uid)).data.role == 'ADMIN')
      );
    }

    // Access context: ADMIN can see everything, others only their company
    function hasAccess(compName) {
      return isSignedIn() && (
        isAdmin() || 
        (exists(/databases/$(database)/documents/user_permissions/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/user_permissions/$(request.auth.uid)).data.assignedCompany == compName)
      );
    }

    // Modification context: ADMIN and EDITOR can modify company data
    function canModify(compName) {
      return isSignedIn() && (
        isAdmin() || 
        (exists(/databases/$(database)/documents/user_permissions/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/user_permissions/$(request.auth.uid)).data.role == 'EDITOR' &&
         get(/databases/$(database)/documents/user_permissions/$(request.auth.uid)).data.assignedCompany == compName)
      );
    }

    // Plants Registry
    match /plants/{plantId} {
      allow read: if hasAccess(resource.data.companyName);
      allow create: if canModify(request.resource.data.companyName);
      allow update: if canModify(resource.data.companyName);
      allow delete: if isAdmin();
    }

    // P4: Spatial Distribution
    match /fab_cleanroom_occupancy/{id} {
      allow read: if hasAccess(resource.data.companyName);
      allow write: if canModify(resource.data.companyName);
      
      match /floor_ratios/{fid} {
        allow read: if isSignedIn(); // Basic read for list
        allow write: if canModify(get(/databases/$(database)/documents/fab_cleanroom_occupancy/$(id)).data.companyName);
      }
    }

    // P5: Asset Matrix
    match /building_value_ratios/{id} {
      allow read: if hasAccess(resource.data.companyName);
      allow write: if canModify(resource.data.companyName);
      
      match /floor_ratios/{fid} {
        allow read: if isSignedIn();
        allow write: if canModify(get(/databases/$(database)/documents/building_value_ratios/$(id)).data.companyName);
      }
    }

    // P6: Estimations (READER can also simulate)
    match /flood_loss_estimations/{id} {
      allow read: if hasAccess(resource.data.companyName);
      allow write: if hasAccess(request.resource.data.companyName);
    }

    // User Permissions
    match /user_permissions/{userId} {
      allow get: if isSignedIn();
      allow write: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
    }
  }
}