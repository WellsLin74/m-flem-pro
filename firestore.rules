
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    // Improved user data retrieval with default fallback
    function getUserData() {
      let path = /databases/$(database)/documents/user_permissions/$(request.auth.uid);
      return exists(path) ? get(path).data : { "role": "READER", "assignedCompany": "" };
    }

    // Role-based check
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'ADMIN';
    }

    // Check company access or admin override
    function hasCompanyAccess(companyName) {
      if (!isSignedIn()) return false;
      let userData = getUserData();
      return (
        userData.role == 'ADMIN' || 
        userData.assignedCompany == companyName ||
        (request.auth.token != null && request.auth.token.assignedCompany == companyName)
      );
    }

    match /user_permissions/{userId} {
      allow get: if isSignedIn();
      allow create, update, delete: if isOwner(userId) || isAdmin();
    }

    match /plants/{plantId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if hasCompanyAccess(request.resource.data.companyName || resource.data.companyName);
    }

    match /fab_cleanroom_occupancy/{id} {
      allow read: if isSignedIn();
      allow write: if hasCompanyAccess(request.resource.data.companyName || resource.data.companyName);
      
      match /floor_ratios/{fid} { 
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
    }

    match /building_value_ratios/{id} {
      allow read: if isSignedIn();
      allow write: if hasCompanyAccess(request.resource.data.companyName || resource.data.companyName);
      
      match /floor_ratios/{fid} { 
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
    }

    match /flood_loss_estimations/{id} {
      allow read: if isSignedIn();
      allow write: if hasCompanyAccess(request.resource.data.companyName || resource.data.companyName);
    }
  }
}
